<?php
$totalCount = $block->getTotalCount();
$currentPage = $block->getCurrentPage();
$pageSize = $block->getPageSize();
$totalPages = ceil($totalCount / $pageSize);
?>

<?php if ($totalPages > 1): ?>
<div class="admin__data-grid-pager">
    <div class="admin__data-grid-pager-wrap">
        <div class="admin__data-grid-pager-info">
            <?= $block->escapeHtml(__('Showing %1-%2 of %3 records', 
                ($currentPage - 1) * $pageSize + 1,
                min($currentPage * $pageSize, $totalCount),
                $totalCount
            )) ?>
        </div>
        <div class="admin__data-grid-pager-pages">
            <?php if ($currentPage > 1): ?>
                <a href="<?= $block->escapeUrl($block->getUrl('*/*/*', ['p' => $currentPage - 1, 'limit' => $pageSize])) ?>" class="action-previous">
                    <span><?= $block->escapeHtml(__('Previous')) ?></span>
                </a>
            <?php endif; ?>
            
            <?php for ($i = max(1, $currentPage - 2); $i <= min($totalPages, $currentPage + 2); $i++): ?>
                <?php if ($i == $currentPage): ?>
                    <span class="page current"><?= $block->escapeHtml($i) ?></span>
                <?php else: ?>
                    <a href="<?= $block->escapeUrl($block->getUrl('*/*/*', ['p' => $i, 'limit' => $pageSize])) ?>" class="page">
                        <?= $block->escapeHtml($i) ?>
                    </a>
                <?php endif; ?>
            <?php endfor; ?>
            
            <?php if ($currentPage < $totalPages): ?>
                <a href="<?= $block->escapeUrl($block->getUrl('*/*/*', ['p' => $currentPage + 1, 'limit' => $pageSize])) ?>" class="action-next">
                    <span><?= $block->escapeHtml(__('Next')) ?></span>
                </a>
            <?php endif; ?>
        </div>
    </div>
</div>
<?php endif; ?>

<script type="text/javascript">
    function clearLogs(days) {
        var message = days === 'all' 
            ? '<?= $block->escapeJs(__('Are you sure you want to delete ALL log entries?')) ?>'
            : '<?= $block->escapeJs(__('Are you sure you want to delete log entries older than %1 days?')) ?>'.replace('%1', days);
        
        if (confirm(message)) {
            var url = '<?= $block->escapeUrl($block->getUrl('*/*/clear')) ?>';
            if (days !== 'all') {
                url += '?days=' + days;
            }
            window.location.href = url;
        }
    }
</script>
